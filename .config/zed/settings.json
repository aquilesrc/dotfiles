{
  "theme": "Adwaita Pastel Dark",

  "vim_mode": true,
  "relative_line_numbers": true,

  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 15,
  "ui_font_family": "Fira Sans Condensed",
  "ui_font_size": 16,

  "tab_bar": {
    "show": false
  },

  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
    "selections_menu": false
  },
  "collaboration_panel": {
    "button": false
  },
  "chat_panel": {
    "button": false
  },
  "assistant": {
    "default_model": {
      "provider": "openai",
      "model": "gpt-4o"
    },
    "version": "2",
    "button": false
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  }
}
